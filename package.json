{
  "name": "dashboard",
  "version": "0.1.0",
  "description": "Modern multi-layout, multilingual (RTL/LTR) Angular 21 admin dashboard",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:prod": "ng serve --configuration production",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "build:prod": "ng build --configuration production --base-href /",
    "watch": "ng build --watch --configuration development",
    "postbuild": "node scripts/stamp-sw.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "analyze": "ng build --configuration production && npx source-map-explorer dist/**/*.js"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@jsverse/transloco": "^7.6.0",
    "@primeuix/themes": "^1.2.3",
    "chart.js": "^4.4.7",
    "fast-xml-parser": "^5.9.3",
    "html2canvas": "^1.4.1",
    "jalali-moment": "^3.3.11",
    "jspdf": "^2.5.2",
    "moment": "^2.30.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xml-js": "^1.6.11",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/vitest-angular": "^1.10.0",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.0.0",
    "@vitest/ui": "^3.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~5.9.0",
    "vitest": "^3.0.0"
  }
}
